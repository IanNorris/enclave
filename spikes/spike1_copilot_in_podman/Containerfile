FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Copilot CLI
# The SDK needs the CLI running in server mode
RUN curl -fsSL https://aka.ms/copilot-cli-linux-amd64 -o /usr/local/bin/copilot \
    && chmod +x /usr/local/bin/copilot

# Install Python dependencies
RUN pip install --no-cache-dir github-copilot-sdk

# Create non-root user workspace
RUN mkdir -p /workspace /state
WORKDIR /workspace

# Copy test script
COPY test_sdk.py /workspace/test_sdk.py

# Default command: run the spike test
CMD ["python", "/workspace/test_sdk.py"]
