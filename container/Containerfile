# Enclave Agent Container
#
# Minimal Python image with the enclave agent package.
# Nix is installed at runtime into a persistent volume (/nix), not baked into the
# image. This keeps layers small so --userns keep-id doesn't choke on ID-mapped copies.
# Copilot SDK is optional — agent runs in echo mode without it.

FROM python:3.12-slim

# Install useful tools and create the runtime user (uid 1000).
# fuse3 provides fusermount3 + /dev/fuse helpers for user-space mounts
# (e.g. mounting disk images). The binary only works if the orchestrator
# also passes --device /dev/fuse + --cap-add SYS_ADMIN at run time; if
# not, it's harmless dead weight (~1MB).
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    git curl jq xz-utils fuse3 && \
    rm -rf /var/lib/apt/lists/* && \
    useradd -m -u 1000 -s /bin/bash agent

# Nix config (read at install time and runtime)
RUN mkdir -p /etc/nix && printf '%s\n' \
    'build-users-group =' \
    'sandbox = false' \
    'filter-syscalls = false' \
    'experimental-features = nix-command flakes' \
    'always-allow-substitutes = true' \
    'use-xdg-base-directories = true' \
    > /etc/nix/nix.conf

# Pre-create /nix so the runtime install script can write to it.
# Owned by uid 1000 (the runtime user via --userns keep-id).
RUN mkdir -m 0755 /nix && chown 1000:1000 /nix

# Cache the nix installer tarball so first-run install is fast even without network
RUN curl -L -o /opt/nix-install.sh https://nixos.org/nix/install && \
    chmod +x /opt/nix-install.sh

# Setup script that installs nix on first run (idempotent)
RUN printf '#!/bin/bash\n\
PROFILE_DIR="/nix/var/nix/profiles/per-user/$(whoami)"\n\
\n\
# Find nix binary in store\n\
find_nix() { find /nix/store -maxdepth 3 -name nix-env -path "*/bin/*" 2>/dev/null | head -1; }\n\
NIX_ENV=$(find_nix)\n\
\n\
if [ ! -e "$PROFILE_DIR/profile" ]; then\n\
  mkdir -p /nix/var/nix/profiles/per-user 2>/dev/null\n\
  chmod 1777 /nix/var/nix/profiles/per-user 2>/dev/null\n\
  mkdir -p "$PROFILE_DIR" 2>/dev/null\n\
\n\
  if [ -z "$NIX_ENV" ]; then\n\
    echo "Installing Nix (first run)..." >&2\n\
    bash /opt/nix-install.sh --no-daemon 2>&1 | tail -3 >&2\n\
    NIX_ENV=$(find_nix)\n\
  fi\n\
\n\
  if [ -n "$NIX_ENV" ]; then\n\
    NIX_STORE_PATH=$(dirname "$(dirname "$NIX_ENV")")\n\
    "$NIX_ENV" -p "$PROFILE_DIR/profile" -i "$NIX_STORE_PATH" 2>/dev/null\n\
  fi\n\
fi\n\
\n\
# Create ~/.nix-profile symlink if missing\n\
[ ! -e "$HOME/.nix-profile" ] && [ -e "$PROFILE_DIR/profile" ] && \\\n\
  ln -sf "$PROFILE_DIR/profile" "$HOME/.nix-profile"\n\
\n\
# Source nix profile and export PATH\n\
[ -f "$HOME/.nix-profile/etc/profile.d/nix.sh" ] && . "$HOME/.nix-profile/etc/profile.d/nix.sh"\n\
export PATH="$HOME/.nix-profile/bin:$PATH"\n\
export NIX_PATH="nixpkgs=channel:nixpkgs-unstable"\n\
' > /usr/local/bin/nix-env-setup.sh && chmod +x /usr/local/bin/nix-env-setup.sh

# Install enclave package
COPY pyproject.toml /build/
COPY src/ /build/src/
RUN pip install --no-cache-dir /build && rm -rf /build

# The github-copilot-sdk wheel on PyPI ships an older bundled `copilot` binary
# (e.g. 1.0.21) that returns "Unknown error" on some model requests. Run the
# CLI's self-update to grab the latest release and replace the in-place binary.
# HOME must be writable because `copilot update` caches the downloaded tarball
# under $HOME/.cache/copilot/pkg/. Errors are ignored so builds still succeed
# offline — the runtime will just use the bundled version in that case.
# The github-copilot-sdk wheel on PyPI ships a bundled `copilot` binary that
# extracts its embedded JS bundle to $HOME/.cache/copilot/pkg/<version>/ on
# first run. CLI 1.0.35 has a regression in Ice() (the user-permission-response
# resolver): it only accepts the interactive kinds (approve-once / reject /
# user-not-available) and rejects the SDK result kinds (approved /
# denied-interactively-by-user / denied-by-rules / ...) that the Python SDK
# emits — breaking every shell/write/mcp/memory tool call routed via a
# registered on_permission_request handler with "unexpected user permission
# response". We:
#   1. Run the binary once under a known HOME so the JS bundle is extracted.
#   2. Patch Ice() to add the missing cases (and its renamed twin in app.js).
#   3. Stage the patched bundle under /opt/copilot-cache so we can seed each
#      runtime user's $HOME/.cache/copilot from it.
#   4. Disable auto-update at runtime so the patched files aren't overwritten.
RUN export HOME=/tmp/copilot-extract && mkdir -p "$HOME" && \
    /usr/local/lib/python3.12/site-packages/copilot/bin/copilot update 2>&1 | tail -3 && \
    /usr/local/lib/python3.12/site-packages/copilot/bin/copilot --version && \
    rm -rf /tmp/copilot-extract

# Patch script applied at container start (see entrypoint.sh): extends the
# bundled CLI's Ice() permission-response handler to accept the Python SDK's
# result kinds. 1.0.35 introduced a regression where Ice only handles the
# interactive-CLI kinds (approve-once/reject/user-not-available) and falls
# through to "unexpected user permission response" for the SDK kinds
# (approved/denied-*), breaking every shell/write/mcp/memory tool call routed
# through a registered on_permission_request handler. We patch at runtime
# because the single-binary CLI re-extracts its JS bundle into
# $HOME/.cache/copilot/pkg/<platform>/<version>/ on startup, potentially
# overwriting any build-time patch.
COPY container/patch-copilot-cli.py /usr/local/bin/patch-copilot-cli.py
RUN chmod +x /usr/local/bin/patch-copilot-cli.py

WORKDIR /workspace

# Entrypoint: install Nix on first run (if profile uses it), then start agent
# If ENCLAVE_NIX_SHELL is set, wrap execution in nix-shell for that environment.
# On nix-shell failure, falls back to running without it and sets error env vars.
RUN printf '#!/bin/bash\n\
# Disable CLI auto-update so our Ice() patch is not clobbered by a later\n\
# release that may or may not have fixed the regression.\n\
export COPILOT_AUTO_UPDATE=false\n\
\n\
# Trigger the bundled CLI to extract its JS bundle into $HOME/.cache/copilot\n\
# (idempotent — a no-op if already extracted), then patch Ice() to accept the\n\
# Python-SDK permission result kinds. Fails open: if the patch script errors\n\
# or the pattern no longer matches (e.g. upstream fixed it), the agent still\n\
# starts.\n\
/usr/local/lib/python3.12/site-packages/copilot/bin/copilot --version >/dev/null 2>&1 || true\n\
/usr/local/bin/patch-copilot-cli.py || true\n\
\n\
if [ "${ENCLAVE_NIX_STORE:-0}" = "1" ]; then\n\
  source /usr/local/bin/nix-env-setup.sh\n\
fi\n\
\n\
if [ -n "${ENCLAVE_NIX_SHELL:-}" ]; then\n\
  ENCLAVE_PYTHON="$(which python3)"\n\
  NIX_SHELL_LOG="/workspace/.nix-shell.log"\n\
  echo "[entrypoint] Testing nix-shell: $ENCLAVE_NIX_SHELL" > "$NIX_SHELL_LOG" 2>&1\n\
  if nix-shell "$ENCLAVE_NIX_SHELL" --run "echo nix-shell-ok" >> "$NIX_SHELL_LOG" 2>&1; then\n\
    echo "[entrypoint] nix-shell OK, launching agent under nix-shell" >> "$NIX_SHELL_LOG"\n\
    exec nix-shell "$ENCLAVE_NIX_SHELL" --command "$ENCLAVE_PYTHON -m enclave.agent.main $*"\n\
  else\n\
    echo "[entrypoint] nix-shell FAILED (exit $?), falling back to plain exec" >> "$NIX_SHELL_LOG"\n\
    export ENCLAVE_NIX_SHELL_FAILED=1\n\
    export ENCLAVE_NIX_SHELL_LOG="$NIX_SHELL_LOG"\n\
  fi\n\
fi\n\
\n\
exec python3 -m enclave.agent.main "$@"\n\
' > /usr/local/bin/entrypoint.sh && chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
