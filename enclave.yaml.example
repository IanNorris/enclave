matrix:
  homeserver: "https://your.homeserver"
  user_id: "@enclave-dev:your.homeserver"
  password: 'YOUR_PASSWORD_HERE'
  device_name: "Enclave Orchestrator"
  store_path: "/home/ian/.local/share/enclave/matrix_store"
  control_room_id: "!rrPHYeAltLgbZwwGJJ:your.homeserver"
  space_id: ""

container:
  image: "enclave-agent:latest"       # Default image (used if no profile matches)
  runtime: "podman"
  network: "none"             # Default network for non-SDK containers (isolated)
  copilot_network: "slirp4netns"  # Network mode when Copilot SDK is enabled
  dns: ""                     # Optional custom DNS (e.g. "1.1.1.1" to restrict resolver)
  userns: "keep-id"
  workspace_base: "/home/ian/.local/share/enclave/workspaces"
  session_base: "/home/ian/.local/share/enclave/sessions"
  socket_dir: "/home/ian/.local/share/enclave/sockets"
  github_token: ""  # GitHub token for Copilot SDK auth (from `gh auth token`)
  default_profile: "dev"
  profiles:
    dev:
      image: "enclave-agent:latest"   # Full image with nix + host tool access
      nix_store: true
      host_mounts: true
    light:
      image: "enclave-light:latest"   # Minimal (~200MB), no nix, no host mounts
      nix_store: false
      host_mounts: false

users:
  - matrix_id: "@your_user:your.homeserver"
    linux_user: "ian"
    max_sessions: 10
    can_approve_privilege: true

log_level: "DEBUG"
data_dir: "/home/ian/.local/share/enclave"
